# DocForge — Environment Configuration
# Copy this file to .env and fill in your values
# Never commit .env to version control

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development               # development | production
SECRET_KEY=change-me-use-32-random-chars-minimum

# Origins allowed to call the API (JSON list)
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8000","http://localhost"]

# ── File handling ─────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=200
MAX_BATCH_FILES=20
FILE_RETENTION_HOURS=24           # auto-delete processed files after N hours

# ── External tools (usually auto-detected, override if needed) ────────────────
LIBREOFFICE_PATH=/usr/bin/libreoffice
GHOSTSCRIPT_PATH=/usr/bin/gs
TESSERACT_PATH=/usr/bin/tesseract
# POPPLER_PATH=                   # leave empty to use system PATH

# ── OpenAI (for AI features) ─────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-your-key-here
OPENAI_MODEL=gpt-4o               # gpt-4o | gpt-4o-mini | gpt-4-turbo | gpt-3.5-turbo
OPENAI_MAX_TOKENS=4096

# ── Performance ───────────────────────────────────────────────────────────────
WORKERS=4                         # uvicorn worker count (set to CPU cores)
MAX_QUEUE_SIZE=100

# ── Storage backend ───────────────────────────────────────────────────────────
STORAGE_BACKEND=local             # local | s3

# S3 / MinIO (only if STORAGE_BACKEND=s3)
# S3_BUCKET=docforge
# S3_ENDPOINT=http://minio:9000   # leave empty for AWS S3
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin
# S3_REGION=us-east-1
